{
  "schema_version": 1,
  "quilt_loader": {
    "group": "${group}",
    "id": "gradlemc",
    "version": "${version}",
    "metadata": {
      "name": "GradleMC",
      "description": "In-game diagnostics and stability checker for Minecraft modpacks.",
      "contributors": {
        "Soumyajit": "Owner"
      },
      "license": "Apache-2.0",
      "icon": "GradleMC_logo.png"
    },
    "intermediate_mappings": "net.fabricmc:intermediary",
    "entrypoints": {
      "init": "com.soumyajit.gradlemc.quilt.GradleMCQuilt",
      "client_init": "com.soumyajit.gradlemc.quilt.GradleMCQuiltClient"
    },
    "depends": [
      {
        "id": "quilt_loader",
        "versions": ">=0.29.2"
      },
      {
        "id": "quilted_fabric_api",
        "versions": ">=7.7.0"
      },
      {
        "id": "minecraft",
        "versions": {
          "all": [
            ">=1.20.1-",
            "<1.20.2-"
          ]
        }
      },
      {
        "id": "java",
        "versions": ">=17"
      }
    ]
  }
}
